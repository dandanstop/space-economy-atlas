{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "space-economy-proxy",
  "main": "cloudflare/space-economy-proxy.js",
  "compatibility_date": "2026-06-19",
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "dandanstop.me/space-economy*",
      "zone_name": "dandanstop.me"
    }
  ],
  "observability": {
    "enabled": true
  }
}
