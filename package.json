{
  "name": "space-economy-atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/serve.mjs",
    "audio:elevenlabs": "node scripts/generate-elevenlabs-audio.mjs",
    "render:og": "node scripts/render-og-image.cjs",
    "build": "node scripts/verify-static.mjs",
    "vercel:build": "npm run build && node scripts/build-vercel.mjs",
    "test": "node --test",
    "verify:browser": "node scripts/verify-browser.cjs",
    "cf:wrangler": "WRANGLER_LOG_PATH=.wrangler/logs wrangler",
    "cf:login": "WRANGLER_LOG_PATH=.wrangler/logs wrangler login",
    "cf:whoami": "WRANGLER_LOG_PATH=.wrangler/logs wrangler whoami",
    "cf:dry-run": "WRANGLER_LOG_PATH=.wrangler/logs wrangler deploy --dry-run",
    "cf:deploy": "WRANGLER_LOG_PATH=.wrangler/logs wrangler deploy"
  },
  "dependencies": {
    "three": "^0.165.0"
  },
  "devDependencies": {
    "wrangler": "^4.102.0"
  }
}
